# ── OpenAI ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini

# ── YouTube ─────────────────────────────────────────────
YOUTUBE_API_KEY=AIza...

# ── Spotify ─────────────────────────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# 개발: http://127.0.0.1:8000/spotify/callback
# 배포: https://yourdomain.com/spotify/callback
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/spotify/callback

# ── ACRCloud ─────────────────────────────────────────────
ACRCLOUD_HOST=identify-ap-southeast-1.acrcloud.com
ACRCLOUD_ACCESS_KEY=
ACRCLOUD_ACCESS_SECRET=

# ── yt-dlp 쿠키 (서버 배포 시 YouTube 차단 우회용) ────────
# 브라우저에서 내보낸 cookies.txt 경로. 비워두면 쿠키 없이 시도.
# 추출 방법: yt-dlp --cookies-from-browser chrome --cookies cookies.txt
YTDLP_COOKIE_FILE=

# ── 프론트엔드/백엔드 URL ────────────────────────────────
# 개발: http://127.0.0.1:5500 또는 http://localhost:5173
# 배포: https://yourdomain.com
FRONTEND_URL=http://127.0.0.1:5500
# 복수 허용 출처는 쉼표로 구분
FRONTEND_ALLOWED_ORIGINS=

# ── 세션 쿠키 ────────────────────────────────────────────
SPOTIFY_SESSION_COOKIE_NAME=ob_session
SPOTIFY_SESSION_MAX_AGE=2592000
# 배포(HTTPS) 환경에서는 반드시 true로 설정
SPOTIFY_SESSION_COOKIE_SECURE=false

# ── 관리자 ───────────────────────────────────────────────
ADMIN_KEY=
